{
  "name": "financas",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "test:unit": "pnpm --filter api test && pnpm --filter web test && pnpm --filter @financas/shared test",
    "test:e2e": "pnpm --filter api test:e2e",
    "ci:static": "pnpm prisma:validate && pnpm prisma:generate && pnpm --filter @financas/shared build && pnpm lint && pnpm typecheck",
    "ci:test": "pnpm test:unit && pnpm test:e2e",
    "ci:build": "pnpm build",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "packageManager": "pnpm@9.15.0"
}
