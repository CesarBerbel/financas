generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FinancialProfileType {
  PERSONAL_BRAZIL
  PERSONAL_PORTUGAL
  BUSINESS_PORTUGAL
}

enum FinancialProfileStatus {
  ACTIVE
  ARCHIVED
}

enum AccountType {
  CHECKING
  SAVINGS
  WALLET
  INVESTMENT
  BUSINESS
  RESERVE
}

enum AccountStatus {
  ACTIVE
  ARCHIVED
  CLOSED
}

enum AuditAction {
  USER_REGISTERED
  PROFILE_CREATED
  PROFILE_UPDATED
  PROFILE_SWITCHED
  ACCOUNT_CREATED
  ACCOUNT_UPDATED
  ACCOUNT_ARCHIVED
  ACCOUNT_CLOSED
}

model User {
  id               String             @id @default(cuid())
  name             String
  email            String             @unique
  passwordHash     String
  locale           String             @default("pt-PT")
  timezone         String             @default("Europe/Lisbon")
  mfaEnabled       Boolean            @default(false)
  trustedDevices   Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  profiles         FinancialProfile[]
  sessions         Session[]
  auditLogs        AuditLog[]
}

model Currency {
  code      String             @id
  name      String
  symbol    String
  createdAt DateTime           @default(now())
  profiles  FinancialProfile[]
  accounts  Account[]
}

model FinancialProfile {
  id           String                 @id @default(cuid())
  userId       String
  name         String
  type         FinancialProfileType
  baseCurrency String
  status       FinancialProfileStatus @default(ACTIVE)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency     Currency               @relation(fields: [baseCurrency], references: [code])
  accounts     Account[]

  @@index([userId, type])
  @@index([userId, status])
}

model Account {
  id                String           @id @default(cuid())
  financialProfileId String
  name              String
  type              AccountType
  currencyCode      String
  initialBalance    Decimal          @default(0) @db.Decimal(18, 2)
  currentBalance    Decimal          @default(0) @db.Decimal(18, 2)
  reconciledBalance Decimal          @default(0) @db.Decimal(18, 2)
  projectedBalance  Decimal          @default(0) @db.Decimal(18, 2)
  status            AccountStatus    @default(ACTIVE)
  description       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  financialProfile  FinancialProfile @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)
  currency          Currency         @relation(fields: [currencyCode], references: [code])

  @@index([financialProfileId, status])
  @@index([currencyCode])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String
  action     AuditAction
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
