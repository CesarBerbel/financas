generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FinancialProfileType {
  PERSONAL_BRAZIL
  PERSONAL_PORTUGAL
  BUSINESS_PORTUGAL
  BUSINESS_USA
}

enum FinancialProfileStatus {
  ACTIVE
  ARCHIVED
}

enum AccountType {
  CHECKING
  SAVINGS
  WALLET
  INVESTMENT
  BUSINESS
  RESERVE
}

enum AccountStatus {
  ACTIVE
  ARCHIVED
  CLOSED
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  ADJUSTMENT
}

enum AuditAction {
  USER_REGISTERED
  PROFILE_CREATED
  PROFILE_UPDATED
  PROFILE_SWITCHED
  ACCOUNT_CREATED
  ACCOUNT_UPDATED
  ACCOUNT_ARCHIVED
  ACCOUNT_CLOSED
  TRANSACTION_CREATED
  TRANSACTION_UPDATED
  TRANSACTION_DELETED
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  TAG_CREATED
}

model User {
  id               String             @id @default(cuid())
  name             String
  email            String             @unique
  passwordHash     String
  locale           String             @default("pt-PT")
  timezone         String             @default("Europe/Lisbon")
  mfaEnabled       Boolean            @default(false)
  trustedDevices   Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  profiles         FinancialProfile[]
  sessions         Session[]
  auditLogs        AuditLog[]
  categories       Category[]
  tags             Tag[]
}

model Currency {
  code         String             @id
  name         String
  symbol       String
  createdAt    DateTime           @default(now())
  profiles     FinancialProfile[]
  accounts     Account[]
  transactions Transaction[]
}

model FinancialProfile {
  id           String                 @id @default(cuid())
  userId       String
  name         String
  type         FinancialProfileType
  baseCurrency String
  status       FinancialProfileStatus @default(ACTIVE)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency     Currency               @relation(fields: [baseCurrency], references: [code])
  accounts     Account[]
  transactions Transaction[]
  categories   Category[]
  tags         Tag[]

  @@index([userId, type])
  @@index([userId, status])
}

model Account {
  id                  String           @id @default(cuid())
  financialProfileId  String
  name                String
  type                AccountType
  currencyCode        String
  initialBalance      Decimal          @default(0) @db.Decimal(18, 2)
  currentBalance      Decimal          @default(0) @db.Decimal(18, 2)
  reconciledBalance   Decimal          @default(0) @db.Decimal(18, 2)
  projectedBalance    Decimal          @default(0) @db.Decimal(18, 2)
  status              AccountStatus    @default(ACTIVE)
  description         String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  financialProfile    FinancialProfile @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)
  currency            Currency         @relation(fields: [currencyCode], references: [code])
  transactions        Transaction[]    @relation("AccountTransactions")
  incomingTransfers   Transaction[]    @relation("DestinationAccountTransfers")

  @@index([financialProfileId, status])
  @@index([currencyCode])
}

model Category {
  id                  String            @id @default(cuid())
  userId              String
  financialProfileId  String?
  parentId            String?
  name                String
  normalizedName      String
  isDefault           Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  financialProfile    FinancialProfile? @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)
  parent              Category?         @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children            Category[]        @relation("CategoryHierarchy")
  transactions        Transaction[]

  @@index([userId, financialProfileId])
  @@index([parentId])
  @@index([normalizedName])
}

model Tag {
  id                  String            @id @default(cuid())
  userId              String
  financialProfileId  String
  name                String
  normalizedName      String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  financialProfile    FinancialProfile  @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)
  transactions        TransactionTag[]

  @@unique([userId, financialProfileId, normalizedName])
  @@index([financialProfileId])
}

model Transaction {
  id                   String             @id @default(cuid())
  financialProfileId   String
  accountId            String
  destinationAccountId String?
  categoryId           String?
  type                 TransactionType
  amount               Decimal            @db.Decimal(18, 2)
  currencyCode         String
  description          String
  categoryName         String?
  occurredAt           DateTime
  notes                String?
  deletedAt            DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  financialProfile     FinancialProfile   @relation(fields: [financialProfileId], references: [id], onDelete: Cascade)
  account              Account            @relation("AccountTransactions", fields: [accountId], references: [id])
  destinationAccount   Account?           @relation("DestinationAccountTransfers", fields: [destinationAccountId], references: [id])
  category             Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  currency             Currency           @relation(fields: [currencyCode], references: [code])
  tags                 TransactionTag[]

  @@index([financialProfileId, occurredAt])
  @@index([accountId, occurredAt])
  @@index([destinationAccountId, occurredAt])
  @@index([categoryId])
  @@index([currencyCode])
  @@index([categoryName])
  @@index([deletedAt])
}

model TransactionTag {
  transactionId String
  tagId         String
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@index([tagId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String
  action     AuditAction
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
