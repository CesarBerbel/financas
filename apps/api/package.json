{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "node --watch -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "start:dev": "node --watch -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "build": "pnpm run clean && nest build",
    "start": "node -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "start:prod": "pnpm run build && node dist/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --passWithNoTests",
    "test:e2e": "jest --config jest.e2e.config.cjs --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.1.0",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.14",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0"
  }
}
